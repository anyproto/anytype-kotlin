<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/topToolbar"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:clipChildren="false"
    android:clipToPadding="false">

    <FrameLayout
        android:id="@+id/topBackButton"
        android:layout_width="@dimen/nav_circular_button_size"
        android:layout_height="@dimen/nav_circular_button_size"
        android:layout_marginStart="16dp"
        android:background="@drawable/bg_nav_circular_button"
        android:elevation="4dp"
        android:outlineAmbientShadowColor="@color/nav_chip_shadow"
        android:outlineSpotShadowColor="@color/nav_chip_shadow"
        tools:targetApi="28">

        <ImageView
            android:id="@+id/ivTopBackButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:src="@drawable/ic_default_top_back" />

    </FrameLayout>

    <com.anytypeio.anytype.core_ui.widgets.StatusBadgeWidget
        android:id="@+id/statusBadge"
        android:layout_width="@dimen/nav_circular_button_size"
        android:layout_height="@dimen/nav_circular_button_size"
        android:layout_gravity="center_vertical|end"
        android:scaleType="center"
        android:background="@drawable/bg_nav_circular_button"
        android:layout_marginEnd="68dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:visibility="visible" />

    <LinearLayout
        android:id="@+id/titlePillContainer"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:layout_marginStart="68dp"
        android:layout_marginEnd="120dp"
        android:background="@drawable/bg_nav_pill_container"
        android:clickable="true"
        android:focusable="true"
        android:elevation="4dp"
        android:outlineAmbientShadowColor="@color/nav_chip_shadow"
        android:outlineSpotShadowColor="@color/nav_chip_shadow"
        tools:targetApi="28">

        <com.anytypeio.anytype.core_ui.widgets.ObjectIconWidget
            android:id="@+id/ivTopToolbarIcon"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_gravity="center_vertical"
            android:layout_marginStart="8dp"
            android:visibility="visible"
            app:checkboxSize="20dp"
            app:emojiSize="20dp"
            app:imageSize="20dp"
            app:initialTextSize="11sp"
            tools:visibility="visible" />
        <Space
            android:layout_width="8dp"
            android:layout_height="match_parent"/>

        <TextView
            android:id="@+id/tvTopToolbarTitle"
            style="@style/ObjectSetToolbarTitleStyle"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            tools:text="Your favorite movies" />

    </LinearLayout>

    <FrameLayout
        android:id="@+id/threeDotsButton"
        android:layout_width="@dimen/nav_circular_button_size"
        android:layout_height="@dimen/nav_circular_button_size"
        android:layout_gravity="end|center_vertical"
        android:layout_marginEnd="16dp"
        android:background="@drawable/bg_nav_circular_button"
        android:elevation="4dp"
        android:outlineAmbientShadowColor="@color/nav_chip_shadow"
        android:outlineSpotShadowColor="@color/nav_chip_shadow"
        tools:targetApi="28">

        <ImageView
            android:id="@+id/ivThreeDots"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:src="@drawable/ic_action_more" />

    </FrameLayout>

</FrameLayout>